# Maintainer: Gomasy <nyan@gomasy.jp>
# Contributor: Filipe Laíns <lains@riseup.net>

pkgname=tqsl
pkgver=2.8.4
pkgrel=1
pkgdesc='ARRL LoTW Trusted QSL (TQSL) software'
url='https://www.arrl.org/tqsl-download'
arch=('x86_64' 'aarch64')
license=('custom')
depends=('openssl' 'sqlite' 'expat' 'zlib' 'curl' 'wxwidgets-gtk3')
makedepends=('cmake')
source=("https://www.arrl.org/tqsl/tqsl-$pkgver.tar.gz")
sha512sums=('cca93d2dd044c144fedafb773345638c7e31d9a1bd25e7d8adb492777e494583ebfb26e00895d338b5fd7985567bd4af907ecc88b1738b61715a691979401c10')

build() {
  cd $pkgname-$pkgver

  cmake -B build \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_ALL_EXTRAPROGS=true

  cmake --build build
}

package() {
  cd $pkgname-$pkgver

  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 LICENSE.txt -t "$pkgdir"/usr/share/licenses/$pkgname/
}
