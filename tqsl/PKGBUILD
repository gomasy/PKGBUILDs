# Maintainer: Gomasy <nyan@gomasy.jp>
# Contributor: Filipe Laíns <lains@riseup.net>

pkgname=tqsl
pkgver=2.8.6
pkgrel=1
pkgdesc='ARRL LoTW Trusted QSL (TQSL) software'
url='https://www.arrl.org/tqsl-download'
arch=('x86_64' 'aarch64')
license=('custom')
depends=('openssl' 'sqlite' 'expat' 'zlib' 'curl' 'wxwidgets-gtk3')
makedepends=('cmake')
source=("https://www.arrl.org/tqsl/tqsl-$pkgver.tar.gz")
sha512sums=('82190ca7d7589cfa7e13796f97b0d417590112220fcc159eb6d307fac9271ccd45e58759b1962a00d09efeb62c2a47aa83d40f0b3a13a42473a40e6636da5575')

build() {
  cd $pkgname-$pkgver

  cmake -B build \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_ALL_EXTRAPROGS=true

  cmake --build build
}

package() {
  cd $pkgname-$pkgver

  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 LICENSE.txt -t "$pkgdir"/usr/share/licenses/$pkgname/
}
