# Maintainer: Gomasy <nyan@gomasy.jp>
# Contributor: envolution
# Contributor: FuzzyCheese
# shellcheck shell=bash disable=SC2034,SC2154
pkgname=wfview
pkgver=2.23
pkgrel=1
pkgdesc="Interface for Icom transceivers"
arch=('i686' 'x86_64' 'aarch64')
url="https://wfview.org/"
license=('GPL-3.0-only')
depends=(
  qt5-serialport
  qt5-multimedia
  qcustomplot
  eigen
  qt5-gamepad
  rtaudio
  qt5-websockets
  opus
  hidapi
  portaudio
  libpulse
  glibc
  qt5-base
  systemd-libs
  gcc-libs
)

source=("https://gitlab.com/eliggett/wfview/-/archive/v$pkgver/wfview-v$pkgver.tar.gz")
md5sums=('5e552a5e24d65e2cb75bf62c835d3492')

build() {
  cd "${pkgname}-v${pkgver}"
  mkdir -p build
  cd build
  # Upstream forgot to bump the embedded version string (still "2.22" in v2.23),
  # so pass it explicitly via the VERSION override added in 2.22.
  qmake ../wfview.pro PREFIX=/usr VERSION="$pkgver"
  make
}

package() {
  cd "${pkgname}-v${pkgver}/build"
  make INSTALL_ROOT=${pkgdir} install
}
